{
  "id": "github",
  "name": "GitHub",
  "status": "available",
  "category": "DevOps",
  "summary": "Clone git repos and deploy them anywhere via bindings/registry over github:// URI routes.",
  "description": "GitHub is an external urirun connector that bootstraps projects onto any machine over the URI contract: clone a repo, pull updates, pip install it, and emit its urirun_bindings() so the project can be compiled into a registry and served or host-deployed without logging into the box. Clones land under URIRUN_PROJECTS (default ~/.urirun-projects).",
  "useCases": [
    "Clone a git repo over a URI in a flow.",
    "Install a package straight from a GitHub repo.",
    "Inspect a repo's urirun bindings/registry."
  ],
  "flowExample": [
    "github://host/repo/command/clone",
    "github://host/repo/query/bindings",
    "github://host/package/command/install"
  ],
  "requires": [
    "python>=3.10",
    "git",
    "gh for authenticated GitHub operations",
    "credential vault for token import"
  ],
  "install": {
    "mode": "urirun-extra",
    "pipSpec": "urirun-connector-github @ git+https://github.com/urirun-connectors/urirun-connector-github.git@v0.2.0"
  },
  "provenance": "verified",
  "publisher": {
    "name": "if-uri",
    "url": "https://ifuri.com",
    "github": "https://github.com/urirun-connectors"
  },
  "docsUrl": "https://github.com/urirun-connectors/urirun-connector-github",
  "keywords": [
    "git",
    "github",
    "clone",
    "deploy",
    "bootstrap",
    "registry",
    "connector"
  ],
  "uriSchemes": [
    "github"
  ],
  "routes": [
    "github://host/auth/command/import-to-vault",
    "github://host/auth/query/status",
    "github://host/doctor/query/report",
    "github://host/package/command/install",
    "github://host/issue/command/assign",
    "github://host/issue/command/create",
    "github://host/repo/command/clone",
    "github://host/repo/command/create",
    "github://host/repo/command/pull",
    "github://host/repo/collaborator/command/invite",
    "github://host/repo/query/bindings",
    "github://host/repo/query/list"
  ],
  "examples": [
    {
      "title": "Clone a repo",
      "uri": "github://host/repo/command/clone",
      "payload": {
        "url": "https://github.com/if-uri/urirun.git",
        "dest": "/srv/urirun"
      }
    },
    {
      "title": "Read bindings",
      "uri": "github://host/repo/query/bindings",
      "payload": {
        "dest": "/srv/urirun-connector-llm",
        "module": "urirun_connector_llm"
      }
    }
  ],
  "adapterKinds": [
    "local-function"
  ]
}
